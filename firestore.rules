rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Website visitors may only add an email to the download list.
    match /emails/{doc} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() >= 6
                    && request.resource.data.email.size() < 254
                    && request.resource.data.email
                         .matches('^[^@\\s]+@[^@\\s]+[.][a-zA-Z]{2,}$');
      allow read, update, delete: if false;
    }

    // Public download counter — one shared doc the site reads live and
    // bumps by exactly one per genuine first-time download (deduped client
    // side). Unlike GitHub's asset download_count, this never counts auto
    // updates or the same person re-downloading.
    match /stats/downloads {
      allow read: if true;
      // Seed once (create only fires when the doc doesn't exist yet).
      allow create: if request.resource.data.keys().hasOnly(['count'])
                    && request.resource.data.count is int
                    && request.resource.data.count >= 0;
      // Increment-by-one only — no decrements, no other fields.
      allow update: if request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['count'])
                    && request.resource.data.count == resource.data.count + 1;
      allow delete: if false;
    }

    // Public template gallery.
    match /templates/{id} {
      allow read: if true;

      // Anyone may publish a template (open gallery). Shape is validated;
      // vote counts must start at zero.
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 80
                    && request.resource.data.widgets is list
                    && request.resource.data.widgets.size() > 0
                    && request.resource.data.thumb is string
                    && request.resource.data.upvotes == 0
                    && request.resource.data.downvotes == 0
                    && request.resource.data.score == 0;

      // Updates are limited to vote counters only — content can't be altered.
      allow update: if request.resource.data.diff(resource.data)
                      .affectedKeys()
                      .hasOnly(['upvotes', 'downvotes', 'score']);

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
